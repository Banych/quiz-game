{
	"servers": {
		"supabase": {
			"type": "http",
			"url": "https://mcp.supabase.com/mcp?project_ref=iwnxzdhhrreogxauxehm&features=storage,branching,functions,development"
		},
		"microsoft/playwright-mcp": {
			"command": "/bin/zsh",
			"args": [
				"-lc",
				"source ~/.nvm/nvm.sh && nvm use && npx @playwright/mcp@latest"
			],
			"type": "stdio"
		},
		"com.postman/postman-mcp-server": {
			"type": "stdio",
			"command": "/bin/zsh",
			"args": [
				"-lc",
				"source ~/.nvm/nvm.sh && nvm use && npx @postman/postman-mcp-server@2.5.1"
			],
			"env": {
				"POSTMAN_API_KEY": "${input:POSTMAN_API_KEY}"
			}
		}
	},
	"inputs": [
		{
			"id": "CONTEXT7_API_KEY",
			"type": "promptString",
			"description": "API key for authentication",
			"password": true
		},
		{
			"id": "POSTMAN_API_KEY",
			"type": "promptString",
			"description": "A valid Postman API key.",
			"password": true
		}
	]
}