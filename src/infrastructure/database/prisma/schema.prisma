generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model Quiz {
  id                   String                @id @default(cuid())
  title                String
  status               QuizStatus            @default(Pending)
  currentQuestionIndex Int                   @default(0)
  activeQuestionId     String?
  timePerQuestion      Int                   @default(30)
  allowSkipping        Boolean               @default(false)
  joinCode             String?               @unique
  startTime            DateTime?
  endTime              DateTime?
  timerStartedAt       DateTime?
  timerExpiresAt       DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  scoringAlgorithm     ScoringAlgorithm      @default(EXPONENTIAL_DECAY)
  scoringDecayRate     Float                 @default(2.0)
  answers              Answer[]
  players              Player[]
  questions            Question[]
  leaderboardSnapshots LeaderboardSnapshot[]
  auditLogs            AuditLog[]
}

model Question {
  id              String             @id @default(cuid())
  quizId          String?
  text            String
  mediaUrl        String?
  mediaType       QuestionMediaType?
  options         String[]           @default([])
  correctAnswers  String[]           @default([])
  type            QuestionType
  points          Int                @default(0)
  orderIndex      Int                @default(0)
  isPublished     Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  answersLockedAt DateTime?
  answers         Answer[]
  quiz            Quiz?              @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model Player {
  id                   String                @id @default(cuid())
  quizId               String
  name                 String
  status               PlayerStatus          @default(Active)
  score                Int                   @default(0)
  rank                 Int?
  connectedAt          DateTime              @default(now())
  disconnectedAt       DateTime?
  updatedAt            DateTime              @updatedAt
  lastSeenAt           DateTime              @default(now())
  answers              Answer[]
  quiz                 Quiz                  @relation(fields: [quizId], references: [id], onDelete: Cascade)
  leaderboardSnapshots LeaderboardSnapshot[]

  @@index([quizId])
  @@index([quizId, status])
}

model Answer {
  id          String   @id @default(cuid())
  quizId      String
  playerId    String
  questionId  String
  value       String
  submittedAt DateTime @default(now())
  isCorrect   Boolean?
  points      Int?
  timeTakenMs Int?
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([questionId])
  @@index([playerId])
}

model LeaderboardSnapshot {
  id            String   @id @default(cuid())
  quizId        String
  questionIndex Int
  playerId      String
  score         Int
  rank          Int
  capturedAt    DateTime @default(now())
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, questionIndex])
  @@index([playerId])
  @@map("leaderboard_snapshots")
}

model AuditLog {
  id        String         @id @default(cuid())
  quizId    String?
  actorId   String?
  eventType AuditEventType
  metadata  Json           @default("{}")
  createdAt DateTime       @default(now())
  quiz      Quiz?          @relation(fields: [quizId], references: [id], onDelete: SetNull)

  @@index([quizId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum QuizStatus {
  Pending
  Active
  Completed
}

enum PlayerStatus {
  Active
  Disconnected
  Finished
}

enum QuestionType {
  multiple_choice
  text
  true_false
}

enum QuestionMediaType {
  image
  video
  audio
}

enum ScoringAlgorithm {
  EXPONENTIAL_DECAY
  LINEAR
  FIXED
}

enum AuditEventType {
  quiz_created
  quiz_started
  question_advanced
  question_locked
}
